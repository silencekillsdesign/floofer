# Copy this file to .env, fill in the keys you have, and restart the dev server.

# RescueGroups.org v5 API key — the only API with real euthanasia-risk fields.
# Request one (free, read-only) at:
# https://rescuegroups.org/services/adoptable-pet-data-api/
NUXT_RESCUEGROUPS_API_KEY=

# Public site URL — used for Open Graph share cards and canonical links.
# Set this to your real Netlify URL so shared dog links preview correctly.
NUXT_PUBLIC_SITE_URL=

# Optional: error monitoring. Leave blank to keep Sentry inert.
NUXT_PUBLIC_SENTRY_DSN=

# Petfinder v2 API — largest adoptable-pet inventory, great media.
# Get instantly at https://www.petfinder.com/developers/ ("Get an API Key"):
# the "API Key" is the client id, plus its Secret.
NUXT_PETFINDER_API_KEY=
NUXT_PETFINDER_SECRET=
